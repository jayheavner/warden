#!/bin/bash
# warden CLI: refresh (root or WARDEN_DEST test mode), selftest, status.
set -uo pipefail
DEST="${WARDEN_DEST:-/Library/Application Support/ClaudeCode}"
WD="$DEST/warden"
DAEMON_LABEL="com.warden.refresh"

health() {  # health <ok|fail> <registry+settings paths | error text>
  python3 - "$WD/last-refresh.json" "$@" <<'PY'
import datetime, json, os, sys
path, verdict = sys.argv[1], sys.argv[2]
rec = {"ok": verdict == "ok",
       "ts": datetime.datetime.now().astimezone().isoformat()}
if verdict == "ok":
    reg = json.load(open(sys.argv[3]))
    ms = json.load(open(sys.argv[4]))
    rec["repos"] = len(reg["repos"])
    rec["deny"] = len(ms["sandbox"]["filesystem"]["denyWrite"])
else:
    rec["error"] = sys.argv[3][:500]
tmp = path + ".tmp"
json.dump(rec, open(tmp, "w"))
os.replace(tmp, path)
PY
}

userfallback() {  # userfallback [--disabled|--remove]
  # Enterprise-override stopgap: deliver the same enforcement through the
  # user-settings layer, which survives remote managed policy. Derive the
  # target user: sudo caller, else (daemon context) the scan dir's owner.
  local IU HOME_DIR US ST
  IU="${SUDO_USER:-}"
  if [ -z "$IU" ] && [ "$(id -u)" -eq 0 ]; then
    IU="$(stat -f%Su "${WARDEN_SCAN_DIR:-$HOME/claude}" 2>/dev/null || true)"
  fi
  HOME_DIR="${IU:+/Users/$IU}"; HOME_DIR="${HOME_DIR:-$HOME}"
  US="${WARDEN_USER_SETTINGS:-$HOME_DIR/.claude/settings.json}"
  ST="${WARDEN_FALLBACK_STATE:-$HOME_DIR/.claude/warden/fallback.json}"
  python3 "$WD/userfallback.py" \
    --managed-settings "$DEST/managed-settings.json" \
    --user-settings "$US" --state "$ST" "$@" || return 1
  if [ "$(id -u)" -eq 0 ] && [ -n "$IU" ]; then
    chown "$IU" "$US" 2>/dev/null || true
    for f in "$ST" "$(dirname "$ST")/settings.json.pre-warden"; do
      [ -f "$f" ] && chown "$IU" "$f" 2>/dev/null
    done
  fi
  return 0
}

audit_event() {  # audit_event <disable|enable>
  AUD="${WARDEN_AUDIT_FILE:-/Users/${SUDO_USER:-$USER}/.claude/warden/audit.jsonl}"
  python3 - "$AUD" "$1" <<'PY' || true
import datetime, json, os, sys
rec = {"ts": datetime.datetime.now().astimezone().isoformat(),
       "event": sys.argv[2], "by_uid": os.getuid(),
       "tool": "warden-cli", "verdict": sys.argv[2]}
os.makedirs(os.path.dirname(sys.argv[1]), exist_ok=True)
open(sys.argv[1], "a").write(json.dumps(rec) + "\n")
PY
}

case "${1:-status}" in
  disable)
    if [ -z "${WARDEN_DEST:-}" ] && [ "$(id -u)" -ne 0 ]; then
      echo "run: sudo warden disable" >&2; exit 1
    fi
    S="$WD/DISABLED"
    if [ -f "$S" ]; then
      echo "warden: already DISABLED (since $(python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))["disabled_at"])' "$S" 2>/dev/null || echo '?'))"
      exit 0
    fi
    # 1) sentinel (atomic: tmp + rename)
    python3 - "$S" <<'PY'
import datetime, json, os, sys
tmp = sys.argv[1] + ".tmp"
json.dump({"disabled_at": datetime.datetime.now().astimezone().isoformat(),
           "by_uid": int(os.environ.get("SUDO_UID") or os.getuid())},
          open(tmp, "w"))
os.replace(tmp, sys.argv[1])
PY
    [ "$(id -u)" -eq 0 ] && { chown root:wheel "$S"; chmod 0644 "$S"; }
    rollback() {
      rm -f "$S"
      "$0" refresh >/dev/null 2>&1 || true
      echo "warden disable: FAILED — rolled back, enforcement still ON" >&2
      exit 1
    }
    # 2) disabled renders (claude; codex if installed)
    SCAN_HOME="${SUDO_USER:+/Users/$SUDO_USER}"; SCAN_HOME="${SCAN_HOME:-$HOME}"
    python3 "$WD/render.py" --disabled \
      --scan "${WARDEN_SCAN_DIR:-$SCAN_HOME/claude}" \
      --base "${WARDEN_BASE_OVERRIDE:-$WD/managed-settings.base.json}" \
      --write-settings "$DEST/managed-settings.json" \
      --write-registry "$WD/registry.json" \
      --write-gitconfig "$WD/warden.gitconfig" || rollback
    userfallback --disabled || rollback
    CWD_CODEX="${WARDEN_CODEX_DEST:-/etc/codex}/warden"
    if [ -d "$CWD_CODEX" ]; then
      # prefer warden's own renderer over the codex copy: a stale codex
      # install must not be able to block the machine-wide failsafe
      RENDER="$WD/render.py"; [ -f "$RENDER" ] || RENDER="$CWD_CODEX/render.py"
      python3 "$RENDER" --format codex --disabled \
        --scan "${WARDEN_SCAN_DIR:-$SCAN_HOME/claude}" \
        --base "$CWD_CODEX/requirements.base.toml" \
        --write-settings "${WARDEN_CODEX_DEST:-/etc/codex}/requirements.toml" \
        --write-registry "$CWD_CODEX/registry.json" || rollback
    fi
    # 3) refresh daemon out (landd stays — it is a service, not enforcement)
    if [ -z "${WARDEN_DEST:-}" ]; then
      launchctl bootout "system/$DAEMON_LABEL" 2>/dev/null || true
    fi
    audit_event disable
    echo "sentinel: $S"
    echo "settings: sandbox off, hooks kept (banner active)"
    [ -d "$CWD_CODEX" ] && echo "codex: requirements.toml disabled render"
    echo "daemon: $DAEMON_LABEL booted out (com.warden.landd untouched)"
    echo "note: for stale-policy denials, 'sudo warden refresh' is the lighter fix."
    echo "warden is DISABLED. Bash writes in already-running sessions stay sandboxed until those sessions restart."
    ;;
  enable)
    if [ -z "${WARDEN_DEST:-}" ] && [ "$(id -u)" -ne 0 ]; then
      echo "run: sudo warden enable" >&2; exit 1
    fi
    S="$WD/DISABLED"
    if [ ! -f "$S" ]; then echo "warden: already enabled"; exit 0; fi
    SINCE="$(python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))["disabled_at"])' "$S" 2>/dev/null || echo '?')"
    rm -f "$S"
    reinstate() {
      python3 - "$S" <<'PY'
import datetime, json, os, sys
json.dump({"disabled_at": datetime.datetime.now().astimezone().isoformat(),
           "by_uid": int(os.environ.get("SUDO_UID") or os.getuid()),
           "note": "enable failed; re-disabled"}, open(sys.argv[1], "w"))
PY
      echo "warden enable: FAILED — state remains DISABLED" >&2
      exit 1
    }
    "$0" refresh || reinstate          # always a FRESH render, never stale
    python3 - "$DEST/managed-settings.json" <<'PY' || reinstate
import json, sys
d = json.load(open(sys.argv[1]))
assert d["sandbox"]["enabled"] and d["sandbox"]["failIfUnavailable"]
assert d["sandbox"]["allowUnsandboxedCommands"] is False
assert d["hooks"]["PreToolUse"]
print("policy verified: sandbox fail-closed, hooks wired,",
      len(d["sandbox"]["filesystem"]["denyWrite"]), "denyWrite entries")
PY
    if [ -z "${WARDEN_DEST:-}" ]; then
      launchctl bootstrap system /Library/LaunchDaemons/com.warden.refresh.plist 2>/dev/null || true
      launchctl print "system/$DAEMON_LABEL" >/dev/null 2>&1 || reinstate
    fi
    audit_event enable
    echo "warden is ENABLED (was disabled since $SINCE)."
    echo "note: sessions started while disabled stay unenforced until restarted."
    ;;
  refresh)
    if [ -z "${WARDEN_DEST:-}" ] && [ "$(id -u)" -ne 0 ]; then
      echo "run: sudo warden refresh" >&2; exit 1
    fi
    LOG="$WD/refresh.log"
    if [ -f "$LOG" ] && [ "$(stat -f%z "$LOG" 2>/dev/null || echo 0)" -gt 524288 ]; then
      tail -c 65536 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
    fi
    SCAN_HOME="${SUDO_USER:+/Users/$SUDO_USER}"
    SCAN_HOME="${SCAN_HOME:-$HOME}"
    BASE="${WARDEN_BASE_OVERRIDE:-$WD/managed-settings.base.json}"
    if err="$(python3 "$WD/render.py" \
        --scan "${WARDEN_SCAN_DIR:-$SCAN_HOME/claude}" \
        --base "$BASE" \
        --write-settings "$DEST/managed-settings.json" \
        --write-registry "$WD/registry.json" \
        --write-gitconfig "$WD/warden.gitconfig" 2>&1)"; then
      echo "$err"
      if [ "$(id -u)" -eq 0 ]; then
        chown root:wheel "$DEST/managed-settings.json" "$WD/registry.json" "$WD/warden.gitconfig"
        chmod 0644 "$DEST/managed-settings.json" "$WD/registry.json" "$WD/warden.gitconfig"
      fi
      # user-settings fallback must track the managed render (Enterprise
      # remote policy discards the policySettings layer; the user layer is
      # the one that actually loads there)
      if err2="$(userfallback 2>&1)"; then
        echo "$err2"
      else
        echo "$err2" >&2
        health fail "user-settings fallback: $err2"
        exit 1
      fi
      health ok "$WD/registry.json" "$DEST/managed-settings.json"
      # remoted repos: catch shared checkouts up with origin (pr-lane repos
      # otherwise go stale between lands)
      if [ -f "$WD/landd.py" ]; then
        python3 "$WD/landd.py" --sync-all || true
      fi
      python3 - "$WD/registry.json" <<'PY'
import json, sys
reg = json.load(open(sys.argv[1]))
bad = [r["root"] for r in reg["repos"] if r.get("hookspath_override")]
if bad:
    print("WARNING: local core.hooksPath overrides warden hook in:", *bad)
PY
    else
      echo "$err" >&2
      health fail "$err"
      exit 1
    fi
    # codex harness: refresh /etc/codex policy if installed
    CWD_CODEX="${WARDEN_CODEX_DEST:-/etc/codex}/warden"
    if [ -d "$CWD_CODEX" ]; then
      RENDER="$WD/render.py"; [ -f "$RENDER" ] || RENDER="$CWD_CODEX/render.py"
      python3 "$RENDER" --format codex \
        --scan "${WARDEN_SCAN_DIR:-$SCAN_HOME/claude}" \
        --base "$CWD_CODEX/requirements.base.toml" \
        --write-settings "${WARDEN_CODEX_DEST:-/etc/codex}/requirements.toml" \
        --write-registry "$CWD_CODEX/registry.json"
      if [ "$(id -u)" -eq 0 ]; then
        chown root:wheel "${WARDEN_CODEX_DEST:-/etc/codex}/requirements.toml" "$CWD_CODEX/registry.json"
        chmod 0644 "${WARDEN_CODEX_DEST:-/etc/codex}/requirements.toml" "$CWD_CODEX/registry.json"
      fi
    fi
    ;;
  land)
    # zero-tax integration: request the root landing daemon to fast-forward
    # the shared checkout's HEAD branch to <branch> (default: current branch)
    BRANCH="${2:-$(git branch --show-current)}"
    [ -n "$BRANCH" ] || { echo "warden land: detached HEAD and no branch given" >&2; exit 2; }
    COMMON=$(git rev-parse --git-common-dir) || exit 2
    REPO=$(cd "$COMMON/.." && pwd -P)
    Q="${WARDEN_LAND_QUEUE:-/tmp/claude/warden-land}"
    mkdir -p "$Q"
    REQ="$Q/land-$$-$(date +%s).json"
    python3 - "$REQ" "$REPO" "$BRANCH" <<'EOF'
import json, sys
json.dump({"repo": sys.argv[2], "branch": sys.argv[3]}, open(sys.argv[1], "w"))
EOF
    echo "warden land: requested $BRANCH -> $(basename "$REPO") HEAD branch"
    for _ in $(seq 1 90); do
      if [ -f "$REQ.result" ]; then
        SUMMARY=$(python3 - "$REQ.result" <<'EOF'
import json, sys
d = json.load(open(sys.argv[1]))
ok = d["status"] in ("landed", "landed-remote-only", "pr-opened",
                     "pr-exists", "branch-pushed")
line = d["status"]
if d.get("url"):
    line += " " + d["url"]
if d.get("account"):
    line += " (as %s)" % d["account"]
print("OK" if ok else "NO")
print(line)
print(d.get("reason") or d.get("sha") or "")
EOF
)
        rm -f "$REQ.result" 2>/dev/null || true
        VERDICT=$(echo "$SUMMARY" | sed -n 1p)
        echo "$SUMMARY" | sed -n '2s/^/warden land: /p;3s/^/  /p'
        [ "$VERDICT" = "OK" ] && exit 0 || exit 1
      fi
      sleep 1
    done
    echo "warden land: no response from landing daemon after 90s — is com.warden.landd loaded?" >&2
    exit 1
    ;;
  remote)
    # mediated .git/config write: sessions can't touch the shared checkout's
    # config (denyWrite), so the root daemon validates and applies
    # remote.<name>.url — and nothing else — on request
    if [ "${2:-}" != "add" ] || [ -z "${3:-}" ] || [ -z "${4:-}" ]; then
      echo "usage: warden remote add <name> <url>" >&2; exit 2
    fi
    NAME="$3"; URL="$4"
    COMMON=$(git rev-parse --git-common-dir) || exit 2
    REPO=$(cd "$COMMON/.." && pwd -P)
    Q="${WARDEN_LAND_QUEUE:-/tmp/claude/warden-land}"
    mkdir -p "$Q"
    REQ="$Q/remote-$$-$(date +%s).json"
    python3 - "$REQ" "$REPO" "$NAME" "$URL" <<'EOF'
import json, sys
json.dump({"op": "remote-add", "repo": sys.argv[2], "name": sys.argv[3],
           "url": sys.argv[4]}, open(sys.argv[1], "w"))
EOF
    echo "warden remote: requested $NAME = $URL in $(basename "$REPO")"
    for _ in $(seq 1 90); do
      if [ -f "$REQ.result" ]; then
        SUMMARY=$(python3 - "$REQ.result" <<'EOF'
import json, sys
d = json.load(open(sys.argv[1]))
ok = d["status"] in ("remote-added", "remote-updated", "unchanged")
print("OK" if ok else "NO")
print(d["status"])
print(d.get("reason") or d.get("previous") and "was %s" % d["previous"] or "")
EOF
)
        rm -f "$REQ.result" 2>/dev/null || true
        VERDICT=$(echo "$SUMMARY" | sed -n 1p)
        echo "$SUMMARY" | sed -n '2s/^/warden remote: /p;3s/^/  /p'
        [ "$VERDICT" = "OK" ] && exit 0 || exit 1
      fi
      sleep 1
    done
    echo "warden remote: no response from landing daemon after 90s — is com.warden.landd loaded?" >&2
    exit 1
    ;;
  forget)
    # drop a learned lane lesson so inference runs fresh on the next land
    [ -n "${2:-}" ] || { echo "usage: warden forget <repo-root>" >&2; exit 2; }
    if [ -z "${WARDEN_DEST:-}" ] && [ "$(id -u)" -ne 0 ]; then
      echo "run: sudo warden forget $2" >&2; exit 1
    fi
    PYTHONPATH="$WD" exec python3 - "$2" <<'EOF'
import json, sys
import landd
entry = landd.forget(sys.argv[1])
if entry is None:
    print("warden forget: no lesson recorded for %s" % sys.argv[1])
else:
    print("warden forget: dropped %s" % json.dumps(entry))
EOF
    ;;
  selftest)
    exec bash "$WD/selftest.sh"
    ;;
  verify-claude)
    # Live end-to-end proof that Claude Code sessions are governed: launch a
    # real headless session and require a fresh governed session-start in the
    # audit trail. This is the check that catches the Enterprise-override
    # condition (remote org policy replacing the local managed settings).
    if [ "$(id -u)" -eq 0 ]; then
      echo "warden verify-claude: run unprivileged — it launches a Claude Code session as you" >&2
      exit 1
    fi
    command -v claude >/dev/null 2>&1 || { echo "verify-claude: claude CLI not on PATH" >&2; exit 1; }
    AUD="${WARDEN_AUDIT_FILE:-$HOME/.claude/warden/audit.jsonl}"
    count_starts() {
      grep '"verdict": "session-start' "$AUD" 2>/dev/null | grep -cv '"harness": "codex"' || true
    }
    BEFORE=$(count_starts)
    echo "verify-claude: launching a fresh headless Claude Code session..."
    PROBE_DIR=$(mktemp -d "${TMPDIR:-/tmp}/warden-verify.XXXXXX")
    OUT=$( (cd "$PROBE_DIR" && claude -p 'warden verify-claude probe — reply with exactly: ok' 2>&1) )
    RC=$?
    rmdir "$PROBE_DIR" 2>/dev/null || true
    if [ "$RC" -ne 0 ]; then
      echo "verify-claude: FAIL — claude session did not complete (rc=$RC): $OUT" >&2
      exit 1
    fi
    AFTER=$(count_starts)
    if [ "$AFTER" -gt "$BEFORE" ]; then
      echo "verify-claude: PASS — guard hook fired in the fresh session (governed session-start logged in $AUD)"
      exit 0
    fi
    echo "verify-claude: FAIL — the session ran but NO governed session-start was logged."
    echo "  Claude Code sessions on this machine are UNGOVERNED."
    echo "  Likely cause: Claude Enterprise remote policy replaces the local managed-settings"
    echo "  layer. The user-settings fallback should cover this — run: sudo warden refresh"
    echo "  then re-run: warden verify-claude. Audit trail: $AUD"
    exit 1
    ;;
  codex-selftest)
    exec bash "${WARDEN_CODEX_DEST:-/etc/codex}/warden/codex-selftest"
    ;;
  status)
    if [ ! -f "$DEST/managed-settings.json" ]; then
      echo "warden: not installed"; exit 0
    fi
    STATUS_RC=0
    if [ -f "$WD/DISABLED" ]; then
      STATUS_RC=2
      echo "state: DISABLED since $(python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))["disabled_at"])' "$WD/DISABLED" 2>/dev/null || echo '?') (sudo warden enable to re-arm)"
      echo "  sessions started before the disable still enforce Bash-write denials until restarted"
    fi
    n=$(python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));print(len(d["sandbox"]["filesystem"]["denyWrite"]))' "$DEST/managed-settings.json")
    echo "warden: installed ($n denyWrite entries)"
    echo "active in this shell: ${WARDEN_ACTIVE:-no (session started before install?)}"
    # claude delivery: the managed file alone proves nothing — on Claude
    # Enterprise accounts the remote org policy replaces that layer with its
    # own (typically empty) settings. Report the user-settings fallback and
    # the audit evidence of governed sessions.
    US_STATUS="${WARDEN_USER_SETTINGS:-/Users/${SUDO_USER:-$USER}/.claude/settings.json}"
    python3 - "$US_STATUS" "$DEST/managed-settings.json" <<'PY'
import json, sys
try:
    u = json.load(open(sys.argv[1]))
except (OSError, ValueError):
    print("claude fallback: NOT DELIVERED — user settings missing/unreadable; run: sudo warden refresh")
    sys.exit(0)
m = json.load(open(sys.argv[2]))
hooked = any("warden/guard.py" in h.get("command", "")
             for ev in u.get("hooks", {}).values()
             for g in ev for h in g.get("hooks", []))
env_ok = u.get("env", {}).get("WARDEN_ACTIVE") == "1"
have = set(u.get("sandbox", {}).get("filesystem", {}).get("denyWrite", []))
want = set(m["sandbox"]["filesystem"]["denyWrite"])
if not (hooked and env_ok):
    print("claude fallback: NOT DELIVERED (hooks:%s env:%s) — run: sudo warden refresh"
          % (hooked, env_ok))
elif not want <= have:
    print("claude fallback: STALE (%d managed denyWrite entries missing) — run: sudo warden refresh"
          % len(want - have))
else:
    print("claude fallback: delivered (user settings, %d denyWrite entries)" % len(have))
PY
    AUD_STATUS="${WARDEN_AUDIT_FILE:-/Users/${SUDO_USER:-$USER}/.claude/warden/audit.jsonl}"
    python3 - "$AUD_STATUS" <<'PY'
import datetime, json, sys
last = None
try:
    for line in open(sys.argv[1]):
        try:
            r = json.loads(line)
        except ValueError:
            continue
        if (r.get("verdict", "").startswith("session-start")
                and r.get("harness") != "codex"):
            last = r.get("ts")
except OSError:
    pass
if last:
    dt = datetime.datetime.fromisoformat(last)
    s = (datetime.datetime.now().astimezone() - dt).total_seconds()
    age = "%dm ago" % (s // 60) if s < 7200 else "%dh ago" % (s // 3600)
    print("claude sessions: last governed session-start %s" % age)
else:
    print("claude sessions: NO governed session-start EVER observed — Claude Code may be")
    print("  running ungoverned (Enterprise remote policy overrides local managed settings).")
    print("  Prove it live: warden verify-claude")
PY
    if launchctl print "system/$DAEMON_LABEL" >/dev/null 2>&1; then
      echo "daemon: loaded ($DAEMON_LABEL)"
    else
      echo "daemon: NOT LOADED"
    fi
    python3 - "$WD/last-refresh.json" "$WD/registry.json" <<'PY'
import datetime, json, sys
def age(iso):
    dt = datetime.datetime.fromisoformat(iso)
    s = (datetime.datetime.now().astimezone() - dt).total_seconds()
    return "%dm ago" % (s // 60) if s < 7200 else "%dh ago" % (s // 3600)
try:
    h = json.load(open(sys.argv[1]))
    print("refresh: %s %s%s" % ("ok" if h["ok"] else "FAILED", age(h["ts"]),
          "" if h["ok"] else ": " + h.get("error", "?")))
except (OSError, ValueError):
    print("refresh: never ran")
try:
    r = json.load(open(sys.argv[2]))
    print("registry: %d repos, rendered %s" % (len(r["repos"]),
                                               age(r["generated_at"])))
except (OSError, ValueError):
    print("registry: missing")
PY
    # coverage probe: the renderer only adopts shared checkouts one level
    # under a scan root (render.py scan_repos). Repos elsewhere are silently
    # unprotected — surface that instead of leaving it quiet. Bounded walk;
    # prunes adopted repos and heavy vendored trees to stay cheap.
    python3 - "$WD/registry.json" <<'PY'
import json, os, sys
PRUNE = {".git", "node_modules", ".venv", "venv", "vendor", "__pycache__"}
MAXDEPTH, CAP = 5, 10
try:
    reg = json.load(open(sys.argv[1]))
except (OSError, ValueError):
    sys.exit(0)
adopted = {os.path.realpath(r["root"]) for r in reg.get("repos", [])}
if not adopted:
    print("coverage: no repos adopted — check the scan dir (WARDEN_SCAN_DIR)")
roots = [os.path.realpath(os.path.expanduser(s)) for s in reg.get("scanned", [])]
missed = []
for base in roots:
    base_depth = base.rstrip("/").count("/")
    for cur, dirs, _ in os.walk(base):
        if cur.rstrip("/").count("/") - base_depth >= MAXDEPTH:
            dirs[:] = []
            continue
        real = os.path.realpath(cur)
        if real != base and os.path.isdir(os.path.join(cur, ".git")) \
                and real not in adopted:
            missed.append(real)          # a nested shared checkout we skip
            dirs[:] = []                 # don't descend into its internals
            continue
        dirs[:] = [d for d in dirs if d not in PRUNE
                   and os.path.realpath(os.path.join(cur, d)) not in adopted]
if missed:
    print("coverage: %d nested repo(s) NOT protected (only repos one level "
          "under a scan root are adopted):" % len(missed))
    for m in missed[:CAP]:
        print("  " + m)
    if len(missed) > CAP:
        print("  ... and %d more" % (len(missed) - CAP))
PY
    # multi-git governance probe: every git a session might invoke must have
    # the warden include resolvable in ITS system config chain (a Homebrew
    # git reads its own prefix's etc/gitconfig, not /etc/gitconfig).
    CANDIDATES="${WARDEN_GIT_CANDIDATES:-/usr/bin/git:/usr/local/bin/git:/opt/homebrew/bin/git:/opt/local/bin/git}"
    IFS=':' read -ra GITS <<< "$CANDIDATES"
    for g in "${GITS[@]}"; do
      [ -x "$g" ] || continue
      ver="$("$g" --version 2>/dev/null | awk '{print $3}')"
      new_enough="$(printf '%s' "$ver" | awk -F. '{print ($1>2 || ($1==2 && $2>=28)) ? 1 : 0}')"
      if [ "$new_enough" != 1 ]; then
        echo "git: $g $ver TOO OLD (<2.28: reference-transaction hook never runs)"
      elif "$g" config --system --get-all include.path 2>/dev/null | grep -qxF "$WD/warden.gitconfig"; then
        echo "git: $g $ver GOVERNED"
      else
        echo "git: $g $ver NOT GOVERNED (warden include absent from its system config)"
      fi
    done
    if [ -f "$WD/warden.gitconfig" ] && git config --file /etc/gitconfig --get-all include.path 2>/dev/null | grep -qxF "$WD/warden.gitconfig"; then
      echo "hook delivery: /etc/gitconfig include -> warden.gitconfig OK"
    elif [ -f "$WD/warden.gitconfig" ]; then
      echo "hook delivery: warden.gitconfig rendered but /etc/gitconfig include MISSING"
    else
      echo "hook delivery: not rendered"
    fi
    CREQ="${WARDEN_CODEX_DEST:-/etc/codex}/requirements.toml"
    if [ -f "$CREQ" ]; then
      if cn=$(python3 -c 'import tomllib,sys;d=tomllib.loads(open(sys.argv[1]).read());print(len(d["permissions"]["warden"]["filesystem"]))' "$CREQ" 2>&1); then
        echo "codex: installed ($cn filesystem rules)"
      else
        echo "codex: installed but requirements.toml UNPARSEABLE — enforcement inactive; run: sudo warden refresh"
      fi
    else
      echo "codex: not installed"
    fi
    if [ -f "$WD/lanes.py" ]; then
      PYTHONPATH="$WD" python3 - "$WD/registry.json" <<'EOF' || true
import json, sys
import lanes
try:
    repos = json.load(open(sys.argv[1])).get("repos", [])
except (OSError, ValueError):
    repos = []
for r in repos:
    res = lanes.resolve(r["root"])
    print("  lane %-5s (%s)  %s" % (res["lane"], res["provenance"],
                                    r["root"]))
EOF
    fi
    exit "$STATUS_RC"
    ;;
  *)
    echo "usage: warden {disable|enable|refresh|land [branch]|remote add <name> <url>|forget <repo>|selftest|verify-claude|codex-selftest|status}" >&2
    exit 2
    ;;
esac
