#!/bin/bash
# warden CLI: refresh (root or WARDEN_DEST test mode), selftest, status.
set -uo pipefail
DEST="${WARDEN_DEST:-/Library/Application Support/ClaudeCode}"
WD="$DEST/warden"
DAEMON_LABEL="com.warden.refresh"

health() {  # health <ok|fail> <registry+settings paths | error text>
  python3 - "$WD/last-refresh.json" "$@" <<'PY'
import datetime, json, os, sys
path, verdict = sys.argv[1], sys.argv[2]
rec = {"ok": verdict == "ok",
       "ts": datetime.datetime.now().astimezone().isoformat()}
if verdict == "ok":
    reg = json.load(open(sys.argv[3]))
    ms = json.load(open(sys.argv[4]))
    rec["repos"] = len(reg["repos"])
    rec["deny"] = len(ms["sandbox"]["filesystem"]["denyWrite"])
else:
    rec["error"] = sys.argv[3][:500]
tmp = path + ".tmp"
json.dump(rec, open(tmp, "w"))
os.replace(tmp, path)
PY
}

case "${1:-status}" in
  refresh)
    if [ -z "${WARDEN_DEST:-}" ] && [ "$(id -u)" -ne 0 ]; then
      echo "run: sudo warden refresh" >&2; exit 1
    fi
    LOG="$WD/refresh.log"
    if [ -f "$LOG" ] && [ "$(stat -f%z "$LOG" 2>/dev/null || echo 0)" -gt 524288 ]; then
      tail -c 65536 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
    fi
    SCAN_HOME="${SUDO_USER:+/Users/$SUDO_USER}"
    SCAN_HOME="${SCAN_HOME:-$HOME}"
    BASE="${WARDEN_BASE_OVERRIDE:-$WD/managed-settings.base.json}"
    if err="$(python3 "$WD/render.py" \
        --scan "${WARDEN_SCAN_DIR:-$SCAN_HOME/claude}" \
        --base "$BASE" \
        --write-settings "$DEST/managed-settings.json" \
        --write-registry "$WD/registry.json" \
        --write-gitconfig "$WD/warden.gitconfig" 2>&1)"; then
      echo "$err"
      if [ "$(id -u)" -eq 0 ]; then
        chown root:wheel "$DEST/managed-settings.json" "$WD/registry.json" "$WD/warden.gitconfig"
        chmod 0644 "$DEST/managed-settings.json" "$WD/registry.json" "$WD/warden.gitconfig"
      fi
      health ok "$WD/registry.json" "$DEST/managed-settings.json"
      # remoted repos: catch shared checkouts up with origin (pr-lane repos
      # otherwise go stale between lands)
      if [ -f "$WD/landd.py" ]; then
        python3 "$WD/landd.py" --sync-all || true
      fi
      python3 - "$WD/registry.json" <<'PY'
import json, sys
reg = json.load(open(sys.argv[1]))
bad = [r["root"] for r in reg["repos"] if r.get("hookspath_override")]
if bad:
    print("WARNING: local core.hooksPath overrides warden hook in:", *bad)
PY
    else
      echo "$err" >&2
      health fail "$err"
      exit 1
    fi
    ;;
  land)
    # zero-tax integration: request the root landing daemon to fast-forward
    # the shared checkout's HEAD branch to <branch> (default: current branch)
    BRANCH="${2:-$(git branch --show-current)}"
    [ -n "$BRANCH" ] || { echo "warden land: detached HEAD and no branch given" >&2; exit 2; }
    COMMON=$(git rev-parse --git-common-dir) || exit 2
    REPO=$(cd "$COMMON/.." && pwd -P)
    Q="${WARDEN_LAND_QUEUE:-/tmp/claude/warden-land}"
    mkdir -p "$Q"
    REQ="$Q/land-$$-$(date +%s).json"
    python3 - "$REQ" "$REPO" "$BRANCH" <<'EOF'
import json, sys
json.dump({"repo": sys.argv[2], "branch": sys.argv[3]}, open(sys.argv[1], "w"))
EOF
    echo "warden land: requested $BRANCH -> $(basename "$REPO") HEAD branch"
    for _ in $(seq 1 90); do
      if [ -f "$REQ.result" ]; then
        SUMMARY=$(python3 - "$REQ.result" <<'EOF'
import json, sys
d = json.load(open(sys.argv[1]))
ok = d["status"] in ("landed", "landed-remote-only", "pr-opened",
                     "pr-exists", "branch-pushed")
line = d["status"]
if d.get("url"):
    line += " " + d["url"]
if d.get("account"):
    line += " (as %s)" % d["account"]
print("OK" if ok else "NO")
print(line)
print(d.get("reason") or d.get("sha") or "")
EOF
)
        rm -f "$REQ.result" 2>/dev/null || true
        VERDICT=$(echo "$SUMMARY" | sed -n 1p)
        echo "$SUMMARY" | sed -n '2s/^/warden land: /p;3s/^/  /p'
        [ "$VERDICT" = "OK" ] && exit 0 || exit 1
      fi
      sleep 1
    done
    echo "warden land: no response from landing daemon after 90s — is com.warden.landd loaded?" >&2
    exit 1
    ;;
  forget)
    # drop a learned lane lesson so inference runs fresh on the next land
    [ -n "${2:-}" ] || { echo "usage: warden forget <repo-root>" >&2; exit 2; }
    if [ -z "${WARDEN_DEST:-}" ] && [ "$(id -u)" -ne 0 ]; then
      echo "run: sudo warden forget $2" >&2; exit 1
    fi
    PYTHONPATH="$WD" exec python3 - "$2" <<'EOF'
import json, sys
import landd
entry = landd.forget(sys.argv[1])
if entry is None:
    print("warden forget: no lesson recorded for %s" % sys.argv[1])
else:
    print("warden forget: dropped %s" % json.dumps(entry))
EOF
    ;;
  selftest)
    exec bash "$WD/selftest.sh"
    ;;
  status)
    if [ ! -f "$DEST/managed-settings.json" ]; then
      echo "warden: not installed"; exit 0
    fi
    n=$(python3 -c 'import json,sys;d=json.load(open(sys.argv[1]));print(len(d["sandbox"]["filesystem"]["denyWrite"]))' "$DEST/managed-settings.json")
    echo "warden: installed ($n denyWrite entries)"
    echo "active in this shell: ${WARDEN_ACTIVE:-no (session started before install?)}"
    if launchctl print "system/$DAEMON_LABEL" >/dev/null 2>&1; then
      echo "daemon: loaded ($DAEMON_LABEL)"
    else
      echo "daemon: NOT LOADED"
    fi
    python3 - "$WD/last-refresh.json" "$WD/registry.json" <<'PY'
import datetime, json, sys
def age(iso):
    dt = datetime.datetime.fromisoformat(iso)
    s = (datetime.datetime.now().astimezone() - dt).total_seconds()
    return "%dm ago" % (s // 60) if s < 7200 else "%dh ago" % (s // 3600)
try:
    h = json.load(open(sys.argv[1]))
    print("refresh: %s %s%s" % ("ok" if h["ok"] else "FAILED", age(h["ts"]),
          "" if h["ok"] else ": " + h.get("error", "?")))
except (OSError, ValueError):
    print("refresh: never ran")
try:
    r = json.load(open(sys.argv[2]))
    print("registry: %d repos, rendered %s" % (len(r["repos"]),
                                               age(r["generated_at"])))
except (OSError, ValueError):
    print("registry: missing")
PY
    # coverage probe: the renderer only adopts shared checkouts one level
    # under a scan root (render.py scan_repos). Repos elsewhere are silently
    # unprotected — surface that instead of leaving it quiet. Bounded walk;
    # prunes adopted repos and heavy vendored trees to stay cheap.
    python3 - "$WD/registry.json" <<'PY'
import json, os, sys
PRUNE = {".git", "node_modules", ".venv", "venv", "vendor", "__pycache__"}
MAXDEPTH, CAP = 5, 10
try:
    reg = json.load(open(sys.argv[1]))
except (OSError, ValueError):
    sys.exit(0)
adopted = {os.path.realpath(r["root"]) for r in reg.get("repos", [])}
if not adopted:
    print("coverage: no repos adopted — check the scan dir (WARDEN_SCAN_DIR)")
roots = [os.path.realpath(os.path.expanduser(s)) for s in reg.get("scanned", [])]
missed = []
for base in roots:
    base_depth = base.rstrip("/").count("/")
    for cur, dirs, _ in os.walk(base):
        if cur.rstrip("/").count("/") - base_depth >= MAXDEPTH:
            dirs[:] = []
            continue
        real = os.path.realpath(cur)
        if real != base and os.path.isdir(os.path.join(cur, ".git")) \
                and real not in adopted:
            missed.append(real)          # a nested shared checkout we skip
            dirs[:] = []                 # don't descend into its internals
            continue
        dirs[:] = [d for d in dirs if d not in PRUNE
                   and os.path.realpath(os.path.join(cur, d)) not in adopted]
if missed:
    print("coverage: %d nested repo(s) NOT protected (only repos one level "
          "under a scan root are adopted):" % len(missed))
    for m in missed[:CAP]:
        print("  " + m)
    if len(missed) > CAP:
        print("  ... and %d more" % (len(missed) - CAP))
PY
    # multi-git governance probe: every git a session might invoke must have
    # the warden include resolvable in ITS system config chain (a Homebrew
    # git reads its own prefix's etc/gitconfig, not /etc/gitconfig).
    CANDIDATES="${WARDEN_GIT_CANDIDATES:-/usr/bin/git:/usr/local/bin/git:/opt/homebrew/bin/git:/opt/local/bin/git}"
    IFS=':' read -ra GITS <<< "$CANDIDATES"
    for g in "${GITS[@]}"; do
      [ -x "$g" ] || continue
      ver="$("$g" --version 2>/dev/null | awk '{print $3}')"
      new_enough="$(printf '%s' "$ver" | awk -F. '{print ($1>2 || ($1==2 && $2>=28)) ? 1 : 0}')"
      if [ "$new_enough" != 1 ]; then
        echo "git: $g $ver TOO OLD (<2.28: reference-transaction hook never runs)"
      elif "$g" config --system --get-all include.path 2>/dev/null | grep -qxF "$WD/warden.gitconfig"; then
        echo "git: $g $ver GOVERNED"
      else
        echo "git: $g $ver NOT GOVERNED (warden include absent from its system config)"
      fi
    done
    if [ -f "$WD/warden.gitconfig" ] && git config --file /etc/gitconfig --get-all include.path 2>/dev/null | grep -qxF "$WD/warden.gitconfig"; then
      echo "hook delivery: /etc/gitconfig include -> warden.gitconfig OK"
    elif [ -f "$WD/warden.gitconfig" ]; then
      echo "hook delivery: warden.gitconfig rendered but /etc/gitconfig include MISSING"
    else
      echo "hook delivery: not rendered"
    fi
    if [ -f "$WD/lanes.py" ]; then
      PYTHONPATH="$WD" python3 - "$WD/registry.json" <<'EOF' || true
import json, sys
import lanes
try:
    repos = json.load(open(sys.argv[1])).get("repos", [])
except (OSError, ValueError):
    repos = []
for r in repos:
    res = lanes.resolve(r["root"])
    print("  lane %-5s (%s)  %s" % (res["lane"], res["provenance"],
                                    r["root"]))
EOF
    fi
    ;;
  *)
    echo "usage: warden {refresh|land [branch]|forget <repo>|selftest|status}" >&2
    exit 2
    ;;
esac
