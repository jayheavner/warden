<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.warden.refresh</string>
  <key>ProgramArguments</key>
  <array><string>/usr/local/bin/warden</string><string>refresh</string></array>
  <key>WatchPaths</key><array><string>@SCAN_DIR@</string></array>
  <key>StartInterval</key><integer>900</integer>
  <key>ThrottleInterval</key><integer>30</integer>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>WARDEN_SCAN_DIR</key><string>@SCAN_DIR@</string>
  </dict>
  <key>StandardOutPath</key>
  <string>/Library/Application Support/ClaudeCode/warden/refresh.log</string>
  <key>StandardErrorPath</key>
  <string>/Library/Application Support/ClaudeCode/warden/refresh.log</string>
</dict>
</plist>
